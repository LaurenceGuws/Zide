# Conservative public terminal identity for Zide.
# Keep this aligned with docs/terminal/compatibility.md and only advertise
# capabilities that are safe under an xterm-compatible baseline.
zide|Zide terminal emulator,
	Ms=\E]52;%p1%s;%p2%s\E\\,
	Setulc=\E[58:2:%p1%{65536}%/%d:%p1%{256}%/%{255}%&%d:%p1%{255}%&%d%;m,
	XF, Su, Tc, fullkbd,
	Sync=\E[?2026%?%p1%{1}%-%tl%eh%;,
	Smulx=\E[4:%p1%dm,
	use=xterm-256color,
